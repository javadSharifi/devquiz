{
  "name": "devquiz",
  "version": "1.0.0",
  "private": true,
  "description": "DevQuiz — gamified Persian technical-interview flashcards. One codebase, three targets: Chrome MV3, Firefox MV3, static web (GitHub Pages).",
  "type": "module",
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "build": "node build/build.mjs all",
    "build:chrome": "node build/build.mjs chrome",
    "build:firefox": "node build/build.mjs firefox",
    "build:web": "node build/build.mjs web",
    "watch": "node build/build.mjs chrome --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist/chrome dist/firefox dist/web"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.278",
    "esbuild": "^0.24.0",
    "typescript": "^5.6.0",
    "vitest": "^3.0.0"
  }
}
