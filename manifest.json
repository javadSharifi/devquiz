{
  "manifest_version": 3,
  "name": "DevQuiz",
  "version": "1.0.0",
  "description": "DevQuiz — gamified Persian technical-interview flashcards",
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "DevQuiz"
  },
  "background": {
    "service_worker": "dist/background.js",
    "type": "module"
  },
  "icons": {
    "16": "assets/icons/icon16.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  },
  "permissions": ["storage", "alarms", "unlimitedStorage"],
  "host_permissions": ["https://gist.githubusercontent.com/*"],
  "web_accessible_resources": [
    {
      "resources": ["pages/*", "dist/*", "popup/popup.html", "styles/*", "assets/fonts/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
